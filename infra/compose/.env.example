# =============================================================================
# MorphVox Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment
#
# For PRODUCTION with SSL, set:
#   - DOMAIN to your domain name
#   - Strong passwords for DB_PASSWORD, MINIO keys
#   - APP_KEY (generate with: openssl rand -base64 32)
# =============================================================================

# -----------------------------------------------------------------------------
# Domain Configuration (for production SSL)
# -----------------------------------------------------------------------------
DOMAIN=your-domain.com
LETSENCRYPT_EMAIL=your-email@example.com

# -----------------------------------------------------------------------------
# App Settings
# -----------------------------------------------------------------------------
APP_ENV=local
APP_DEBUG=true
# Generate with: php artisan key:generate --show
# Or: echo "base64:$(openssl rand -base64 32)"
APP_KEY=
APP_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_DATABASE=morphvox
DB_USERNAME=morphvox
# For production, use a strong password: openssl rand -base64 24
DB_PASSWORD=secret

# -----------------------------------------------------------------------------
# Redis (optional password for production)
# -----------------------------------------------------------------------------
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# MinIO / S3 Storage
# -----------------------------------------------------------------------------
# For production, use strong credentials
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
AWS_BUCKET=morphvox

# -----------------------------------------------------------------------------
# Voice Models Storage
# -----------------------------------------------------------------------------
# Storage type: "local" or "s3"
VOICE_MODELS_STORAGE=s3

# S3 Configuration (when VOICE_MODELS_STORAGE=s3)
VOICE_MODELS_S3_DISK=s3
VOICE_MODELS_S3_PREFIX=models
VOICE_MODELS_S3_URL_EXPIRATION=60

# Local path (when VOICE_MODELS_STORAGE=local)
# VOICE_MODELS_PATH=/app/storage/models

# -----------------------------------------------------------------------------
# Voice Engine
# -----------------------------------------------------------------------------
VOICE_ENGINE_DEVICE=cuda  # or 'cpu' for CPU-only

# -----------------------------------------------------------------------------
# Frontend URLs (auto-configured in production based on DOMAIN)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8765

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Internal Service Communication
# -----------------------------------------------------------------------------
INTERNAL_SERVICE_TOKEN=change-me-to-a-random-secret

# -----------------------------------------------------------------------------
# Cloudflare Tunnel (cloud deployment)
# -----------------------------------------------------------------------------
CLOUDFLARE_TUNNEL_TOKEN=

# -----------------------------------------------------------------------------
# Cloudflare R2 Backup
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=morphvox-backups

# -----------------------------------------------------------------------------
# Cost Monitoring (Vast.ai)
# -----------------------------------------------------------------------------
VASTAI_API_KEY=
VASTAI_INSTANCE_ID=
COST_ALERT_WEBHOOK=
COST_HARD_CAP=150
COST_WARN_THRESHOLD=80
COST_URGENT_THRESHOLD=100

# -----------------------------------------------------------------------------
# Backup Encryption
# -----------------------------------------------------------------------------
# Key for encrypting .env backups to R2 (generate with: openssl rand -hex 32)
# Store this in your password manager — it is NOT backed up to R2
SECRETS_ENCRYPTION_KEY=

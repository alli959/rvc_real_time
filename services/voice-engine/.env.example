# Voice Engine Environment Variables

# Internal service-to-service token (must match Laravel's INTERNAL_SERVICE_TOKEN)
INTERNAL_TOKEN=

# S3-compatible storage (MinIO)
AWS_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=morphvox

# Model directory
MODEL_DIR=/workspace/rvc_real_time/storage/models
